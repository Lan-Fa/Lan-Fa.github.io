---
import type { CollectionEntry } from 'astro:content'

import { PostPreview } from 'astro-pure/components/pages'
import { Button } from 'astro-pure/user'

interface Props {
  posts: CollectionEntry<'blog'>[]
  visibleCount?: number
  moreLabel: string
  lessLabel: string
  blogHref?: string
  blogLabel: string
  id: string
}

const {
  posts,
  visibleCount = 3,
  moreLabel,
  lessLabel,
  blogHref = '/blog',
  blogLabel,
  id
} = Astro.props

const featuredPosts = posts.slice(0, visibleCount)
const collapsedPosts = posts.slice(visibleCount)
const panelId = `${id}-more-posts`
---

<div class='not-prose' data-post-list={id}>
  <ul class='flex flex-col gap-y-1.5 sm:gap-y-2'>
    {
      featuredPosts.map((post) => (
        <li class='flex flex-col gap-x-2 sm:flex-row'>
          <PostPreview post={post} />
        </li>
      ))
    }
  </ul>
  {
    collapsedPosts.length > 0 && (
      <>
        <div
          id={panelId}
          class='posts-panel'
          data-posts-panel
          data-expanded='false'
          aria-hidden='true'
        >
          <div>
            <ul class='mt-1.5 flex flex-col gap-y-1.5 sm:mt-2 sm:gap-y-2'>
              {collapsedPosts.map((post) => (
                <li class='flex flex-col gap-x-2 sm:flex-row'>
                  <PostPreview post={post} />
                </li>
              ))}
            </ul>
          </div>
        </div>
        <button
          type='button'
          class='posts-toggle'
          data-posts-toggle
          data-more-label={moreLabel}
          data-less-label={lessLabel}
          aria-expanded='false'
          aria-controls={panelId}
        >
          <span data-posts-toggle-label>{moreLabel}</span>
        </button>
      </>
    )
  }
  <Button title={blogLabel} class='mt-3 w-fit self-end' href={blogHref} variant='ahead' />
</div>

<script>
  document.querySelectorAll('[data-post-list]').forEach((postList) => {
    const panel = postList.querySelector('[data-posts-panel]')
    const toggle = postList.querySelector('[data-posts-toggle]')
    const label = postList.querySelector('[data-posts-toggle-label]')

    toggle?.addEventListener('click', () => {
      const isExpanded = toggle.getAttribute('aria-expanded') === 'true'
      const nextExpanded = String(!isExpanded)

      toggle.setAttribute('aria-expanded', nextExpanded)
      panel?.setAttribute('data-expanded', nextExpanded)
      panel?.setAttribute('aria-hidden', String(isExpanded))

      if (label) {
        label.textContent = isExpanded
          ? toggle.getAttribute('data-more-label')
          : toggle.getAttribute('data-less-label')
      }
    })
  })
</script>

<style>
  .posts-panel {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transition:
      grid-template-rows 420ms ease,
      opacity 260ms ease;
  }

  .posts-panel[data-expanded='true'] {
    grid-template-rows: 1fr;
    opacity: 1;
  }

  .posts-panel > div {
    min-height: 0;
    overflow: hidden;
  }

  .posts-toggle {
    margin-top: 0.875rem;
    display: inline-flex;
    min-height: 2.25rem;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    border: 1px solid hsl(var(--border));
    background: hsl(var(--background) / 0.8);
    padding: 0.375rem 0.875rem;
    color: hsl(var(--foreground));
    font-size: 0.875rem;
    font-weight: 500;
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.5),
      0 1px 8px rgb(0 0 0 / 0.05);
    transition:
      border-color 180ms ease,
      background 180ms ease,
      box-shadow 180ms ease,
      transform 180ms ease;
  }

  .posts-toggle:hover {
    border-color: hsl(var(--foreground) / 0.25);
    background: hsl(var(--muted));
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.55),
      0 2px 12px rgb(0 0 0 / 0.08);
  }

  .posts-toggle:active {
    transform: translateY(1px);
  }
</style>
