---
import { Button } from 'astro-pure/user'

type Skill = string | {
  title: string
  href?: string
}

type Props = {
  title: string
  skills: Skill[]
}

const { title, skills } = Astro.props
const normalizedSkills = skills.map((skill) =>
  typeof skill === 'string' ? { title: skill } : skill
)
---

<div class='flex flex-col gap-y-2 md:flex-row md:gap-x-5 md:gap-y-0'>
  <h3 class='w-1/5 font-medium'>{title}</h3>
  <div class='flex flex-row flex-wrap gap-x-4 gap-y-2 md:w-4/5'>
    {
      normalizedSkills.map(({ title, href }) =>
        href ? (
          <Button
            as='a'
            title={title}
            href={href}
            target='_blank'
            rel='noopener noreferrer'
            variant='pill'
          />
        ) : (
          <Button as='button' title={title} variant='pill' />
        )
      )
    }
  </div>
</div>
