---
import { Button, Svg } from 'astro-pure/user'

type Skill =
  | string
  | {
      name: string
      icon?: Promise<typeof import('*.svg?raw')>
    }

type Props = {
  title: string
  skills: Skill[]
}

const { title, skills } = Astro.props

const normalizedSkills = skills.map((skill) =>
  typeof skill === 'string' ? { name: skill } : skill
)
---

<div class='flex flex-col gap-y-2 md:flex-row md:gap-x-5 md:gap-y-0'>
  <h3 class='w-1/5 font-medium'>{title}</h3>
  <div class='flex flex-row flex-wrap gap-x-4 gap-y-2 md:w-4/5'>
    {
      normalizedSkills.map((skill) => (
        <Button as='button' title={skill.name} variant='pill' class='gap-x-1.5'>
          {skill.icon && (
            <Svg
              src={skill.icon}
              fill='currentColor'
              aria-hidden='true'
              class='size-4 shrink-0 text-muted-foreground opacity-80 transition-colors group-hover:text-primary'
              slot='before'
            />
          )}
        </Button>
      ))
    }
  </div>
</div>
