---
import { Image } from 'astro:assets'
import PageLayout from '@/layouts/CommonPage.astro'
import Substats from '@/components/about/Substats.astro'

const headings = [
  { depth: 2, slug: 'hobbies', text: '兴趣爱好' },
  { depth: 2, slug: 'social-networks', text: '社交网络' },
  { depth: 2, slug: 'certificates', text: '所获证书' }
]

const certificates = [
  {
    event: '第 51 届 ICPC 国际大学生程序设计竞赛邀请赛西安站',
    award: '金牌',
    organizer: 'ICPC',
    year: '2026',
    alt: 'ICPC金牌'
  },
  {
    event: '2026 年 ICPC 国际大学生程序设计竞赛全国邀请赛（武汉）暨湖北省赛',
    award: '亚军/金牌',
    organizer: 'ICPC',
    year: '2026',
    alt: 'ICPC亚军/金牌'
  },
  {
    event: '中国高校计算机大赛-程序设计天梯赛',
    award: '个人一等奖',
    organizer: '中国高校计算机大赛',
    year: '2026',
    alt: '程序设计天梯赛个人一等奖'
  },
  {
    event: '第 50 届 ICPC 国际大学生程序设计竞赛亚洲区域赛上海站',
    award: '银牌',
    organizer: 'ICPC',
    year: '2025',
    alt: 'ICPC银牌'
  },
  {
    event: '第 11 届 CCPC 中国大学生程序设计竞赛重庆站',
    award: '银牌',
    organizer: '中国大学生程序设计竞赛组委会',
    year: '2025',
    alt: 'CCPC银牌'
  },
  {
    event: '2025 CCPC 全国邀请赛（郑州）',
    award: '金牌',
    organizer: '中国大学生程序设计竞赛组委会',
    year: '2025',
    alt: 'CCPC金牌'
  }
]

---

<PageLayout title='关于我' {headings}>
  <p>CS Student / ACMer</p>
  <p>
    华中科技大学计算机科学与技术学院智能科学与技术专业在读。专注于 AI、AI Infra、计算机系统等前沿领域的学习与探索。
  </p>

  {/* general-talk */}
  <h2 id='hobbies'>兴趣爱好</h2>
  <ul>
    <li>算法竞赛</li>
    <li>独立游戏</li>
    <li>羽毛球</li>
    <li>钢琴</li>
  </ul>

  {/* social-networks */}
  <h2 id='social-networks'>社交网络</h2>
  <p>
    可以在以下平台找到我：
  </p>
  <Substats
    stats={[
      {
        platform: 'GitHub',
        icon: 'github',
        link: 'https://github.com/Lan-Fa',
        text: ''
      }
    ]}
  />

  {/* certificates */}
  <h2 id='certificates'>所获证书</h2>
  <div class='not-prose flex flex-col gap-3'>
    {
      certificates.map(({ event, award, organizer, year, alt }) => (
        <article class='relative overflow-hidden rounded-lg border bg-muted/70 px-4 py-3 pe-20 shadow-sm transition-all hover:border-foreground/25 hover:bg-muted hover:shadow-md sm:pe-24'>
          <div class='grid grid-cols-[minmax(0,1fr)_5.75rem] gap-x-3 gap-y-1.5 sm:grid-cols-[minmax(0,1fr)_6.5rem_3.5rem] sm:items-center'>
            <h3 class='m-0 text-base font-semibold leading-snug text-foreground sm:text-lg'>
              {event}
            </h3>
            <span class='row-span-2 inline-flex min-h-9 items-center justify-center rounded-lg border border-foreground/10 bg-background/80 px-2.5 text-sm font-semibold text-foreground shadow-[inset_0_1px_0_rgba(255,255,255,0.55),0_1px_6px_rgba(0,0,0,0.06)] backdrop-blur-sm dark:bg-background/60'>
              {award}
            </span>
            <time class='text-sm font-medium text-muted-foreground sm:text-right'>{year}</time>
            <p class='m-0 text-sm text-muted-foreground sm:col-start-1 sm:row-start-2'>
              {organizer}
            </p>
          </div>
          <Image
            src='/src/assets/logos/hust-logo.png'
            alt={alt}
            class='pointer-events-none absolute end-4 top-1/2 size-12 -translate-y-1/2 rounded-full object-contain opacity-70 sm:end-5 sm:size-14 dark:opacity-60'
            loading='lazy'
            width={64}
            height={64}
          />
        </article>
      ))
    }
  </div>
</PageLayout>
