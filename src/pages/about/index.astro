---
import PageLayout from '@/layouts/CommonPage.astro'
import CertificateCard from '@/components/about/CertificateCard.astro'
import Substats from '@/components/about/Substats.astro'

const headings = [
  { depth: 2, slug: 'hobbies', text: '兴趣爱好' },
  { depth: 2, slug: 'social-networks', text: '社交网络' },
  { depth: 2, slug: 'certificates', text: '竞赛荣誉' }
]

const certificates = [
  {
    event: '第 51 届 ICPC 国际大学生程序设计竞赛邀请赛西安站',
    award: '金牌',
    organizer: 'ICPC',
    year: '2026',
    alt: 'ICPC金牌'
  },
  {
    event: '2026 年 ICPC 国际大学生程序设计竞赛全国邀请赛（武汉）暨湖北省赛',
    award: '亚军/金牌',
    organizer: 'ICPC',
    year: '2026',
    alt: 'ICPC亚军/金牌'
  },
  {
    event: '中国高校计算机大赛-程序设计天梯赛',
    award: '个人一等奖',
    organizer: '中国高校计算机大赛',
    year: '2026',
    alt: '程序设计天梯赛个人一等奖'
  },
  {
    event: '第 50 届 ICPC 国际大学生程序设计竞赛亚洲区域赛上海站',
    award: '银牌',
    organizer: 'ICPC',
    year: '2025',
    alt: 'ICPC银牌'
  },
  {
    event: '第 11 届 CCPC 中国大学生程序设计竞赛重庆站',
    award: '银牌',
    organizer: '中国大学生程序设计竞赛组委会',
    year: '2025',
    alt: 'CCPC银牌'
  },
  {
    event: '2025 CCPC 全国邀请赛（郑州）',
    award: '金牌',
    organizer: '中国大学生程序设计竞赛组委会',
    year: '2025',
    alt: 'CCPC金牌'
  }
]

const visibleCertificateCount = 3
const featuredCertificates = certificates.slice(0, visibleCertificateCount)
const collapsedCertificates = certificates.slice(visibleCertificateCount)
---

<PageLayout title='关于我' {headings}>
  <p>CS Student / ACMer</p>
  <p>
    华中科技大学计算机科学与技术学院智能科学与技术专业在读。
  </p>
  <p>
    专注于 AI、AI Infra、计算机系统等领域的学习与探索。
  </p>

  {/* general-talk */}
  <h2 id='hobbies'>兴趣爱好</h2>
  <ul>
    <li>算法竞赛</li>
    <li>独立游戏</li>
    <li>羽毛球</li>
    <li>钢琴</li>
  </ul>

  {/* social-networks */}
  <h2 id='social-networks'>社交网络</h2>
  <p>
    可以在以下平台找到我：
  </p>
  <Substats
    stats={[
      {
        platform: 'GitHub',
        icon: 'github',
        link: 'https://github.com/Lan-Fa',
        text: ''
      }
    ]}
  />

  {/* certificates */}
  <h2 id='certificates'>竞赛荣誉</h2>
  <div class='not-prose' data-certificates>
    <div class='flex flex-col gap-3'>
      {
        featuredCertificates.map((certificate) => (
          <CertificateCard {...certificate} />
        ))
      }
    </div>
    {
      collapsedCertificates.length > 0 && (
        <>
          <div
            id='more-certificates'
            class='certificates-panel'
            data-certificates-panel
            data-expanded='false'
            aria-hidden='true'
          >
            <div>
              <div class='mt-3 flex flex-col gap-3'>
                {collapsedCertificates.map((certificate) => (
                  <CertificateCard {...certificate} />
                ))}
              </div>
            </div>
          </div>
          <button
            type='button'
            class='certificates-toggle'
            data-certificates-toggle
            aria-expanded='false'
            aria-controls='more-certificates'
          >
            <span data-certificates-toggle-label>查看更多</span>
          </button>
        </>
      )
    }
  </div>

  <script>
    const certificatesRoot = document.querySelector('[data-certificates]')
    const certificatesPanel = certificatesRoot?.querySelector('[data-certificates-panel]')
    const certificatesToggle = certificatesRoot?.querySelector('[data-certificates-toggle]')
    const certificatesToggleLabel = certificatesRoot?.querySelector(
      '[data-certificates-toggle-label]'
    )

    certificatesToggle?.addEventListener('click', () => {
      const isExpanded = certificatesToggle.getAttribute('aria-expanded') === 'true'
      const nextExpanded = String(!isExpanded)

      certificatesToggle.setAttribute('aria-expanded', nextExpanded)
      certificatesPanel?.setAttribute('data-expanded', nextExpanded)
      certificatesPanel?.setAttribute('aria-hidden', String(isExpanded))

      if (certificatesToggleLabel) {
        certificatesToggleLabel.textContent = isExpanded ? '查看更多' : '收起列表'
      }
    })
  </script>

  <style>
    .certificates-panel {
      display: grid;
      grid-template-rows: 0fr;
      opacity: 0;
      transition:
        grid-template-rows 420ms ease,
        opacity 260ms ease;
    }

    .certificates-panel[data-expanded='true'] {
      grid-template-rows: 1fr;
      opacity: 1;
    }

    .certificates-panel > div {
      min-height: 0;
      overflow: hidden;
    }

    .certificates-toggle {
      margin-top: 1rem;
      display: inline-flex;
      min-height: 2.25rem;
      align-items: center;
      justify-content: center;
      border-radius: 0.5rem;
      border: 1px solid hsl(var(--border));
      background: hsl(var(--background) / 0.8);
      padding: 0.375rem 0.875rem;
      color: hsl(var(--foreground));
      font-size: 0.875rem;
      font-weight: 500;
      box-shadow:
        inset 0 1px 0 rgb(255 255 255 / 0.5),
        0 1px 8px rgb(0 0 0 / 0.05);
      transition:
        border-color 180ms ease,
        background 180ms ease,
        box-shadow 180ms ease,
        transform 180ms ease;
    }

    .certificates-toggle:hover {
      border-color: hsl(var(--foreground) / 0.25);
      background: hsl(var(--muted));
      box-shadow:
        inset 0 1px 0 rgb(255 255 255 / 0.55),
        0 2px 12px rgb(0 0 0 / 0.08);
    }

    .certificates-toggle:active {
      transform: translateY(1px);
    }
  </style>
</PageLayout>
