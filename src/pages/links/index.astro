---
import PageLayout from '@/layouts/CommonPage.astro'

const linkSections = [
  {
    id: 'learning-resources',
    title: '学习资料',
    description: '值得长期反复翻看的课程与教材。',
    links: [
      {
        title: 'CSAPP',
        description: 'Computer Systems: A Programmer’s Perspective',
        href: 'https://csapp.cs.cmu.edu/3e/home.html'
      },
      {
        title: 'CS336',
        description: 'Stanford CS336: Language Modeling from Scratch',
        href: 'https://cs336.stanford.edu/'
      }
    ]
  },
  {
    id: 'agent-skills',
    title: '工具网站',
    description: '面向 AI Agent 的技能、命令与工作流资源。',
    links: [
      {
        title: 'Skills.sh',
        description: 'AI Agent skills 生态与目录',
        href: 'https://skills.sh/'
      },
      {
        title: 'Linux.do',
        description: '技术交流社区与 AI 相关资源讨论',
        href: 'https://linux.do/'
      }
    ]
  }
]

const headings = linkSections.map(({ id, title }) => ({
  depth: 2,
  slug: id,
  text: title
}))
---

<PageLayout title='常用链接' {headings}>
  <p>这里收纳一些我会反复查阅的技术文档、课程资料和工具入口。</p>

  {
    linkSections.map(({ id, title, description, links }) => (
      <section class='not-prose space-y-5'>
        <div class='space-y-2'>
          <h2 id={id} class='m-0 text-xl font-semibold tracking-normal text-foreground'>
            {title}
          </h2>
          <p class='m-0 max-w-2xl text-sm leading-6 text-muted-foreground'>{description}</p>
        </div>
        <div class='grid gap-4 sm:grid-cols-2'>
          {links.map(({ title, description, href }) => (
            <a
              href={href}
              target='_blank'
              rel='noopener noreferrer'
              class='group rounded-lg border bg-muted/60 px-4 py-4 no-underline shadow-sm transition-all hover:border-foreground/25 hover:bg-muted hover:shadow-md'
            >
              <div class='flex items-start justify-between gap-6'>
                <div class='space-y-2'>
                  <h3 class='m-0 text-base font-semibold leading-6 text-foreground'>{title}</h3>
                  <p class='m-0 text-sm leading-6 text-muted-foreground'>{description}</p>
                </div>
                <span class='mt-0.5 text-muted-foreground transition-transform group-hover:translate-x-0.5'>
                  →
                </span>
              </div>
            </a>
          ))}
        </div>
      </section>
    ))
  }
</PageLayout>
